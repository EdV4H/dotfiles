# Copy this file to ~/.config/claude-skill-share/.env and fill in the values.
# DB IDs are shared with the team — ask whoever set up the Notion database.

# The Notion database ID (32-character hex without dashes, from the database URL).
NOTION_DATABASE_ID=

# The data source URL (used by Notion MCP for queries; format: collection://<uuid>).
NOTION_DATA_SOURCE_URL=

# Owner identifier shown in the shared DB. Recommended: your work email.
# Falls back to `git config user.email` / `user.name` if unset.
SKILL_SHARE_OWNER_EMAIL=
SKILL_SHARE_OWNER_NAME=
